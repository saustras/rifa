NODE_ENV=development
PUBLIC_WEB_URL=http://localhost:5173
ADMIN_WEB_URL=http://localhost:5174
API_BASE_URL=http://localhost:3000
API_DEV_TOKEN=dev-local-token

# Local development can use PGlite, a PostgreSQL-compatible database stored on disk.
# Production/Dokploy must use a real PostgreSQL URL, for example:
# DATABASE_URL=postgresql://rifa:change-me@postgres:5432/rifa
DATABASE_URL=./packages/db/pglite-data

REDIS_URL=redis://localhost:6379
JOB_QUEUE_PREFIX=rifa

PROOF_STORAGE_BUCKET=rifa-local-proofs
PROOF_STORAGE_DIR=./packages/db/proofs
PROOF_STORAGE_REGION=local
PROOF_STORAGE_ENDPOINT=http://localhost:9000
PROOF_MAX_BYTES=5242880

TELEGRAM_BOT_TOKEN=change-me
TELEGRAM_SELLER_CHAT_ID=change-me

# Default sender / SMTP user for buyer notifications.
EMAIL_FROM=federendon26@hotmail.com

# Outlook/Hotmail SMTP defaults: host smtp-mail.outlook.com, port 587, STARTTLS.
# Keep SMTP_PASSWORD as a real app password/secret outside source control.
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=federendon26@hotmail.com
SMTP_PASSWORD=change-me

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
