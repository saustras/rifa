{
  "name": "config",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/config/src",
  "tags": ["scope:config"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/config/tsconfig.lib.json" },
      "outputs": ["{workspaceRoot}/dist/packages/config"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/config/tsconfig.lib.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/config/src --ext .ts" }
    }
  }
}
