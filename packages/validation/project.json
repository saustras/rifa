{
  "name": "validation",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/validation/src",
  "tags": ["scope:validation"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/validation/tsconfig.lib.json" },
      "outputs": ["{workspaceRoot}/dist/packages/validation"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/validation/tsconfig.lib.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/validation/src --ext .ts" }
    }
  }
}
