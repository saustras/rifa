# Copy these values into Dokploy environment variables. Do not commit real secrets.

POSTGRES_DB=rifa
POSTGRES_USER=rifa
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_HOST_PORT=55432
API_HOST_PORT=3000
PUBLIC_WEB_HOST_PORT=80
ADMIN_WEB_HOST_PORT=8080
DATABASE_URL=postgresql://rifa:change-me-long-random-password@postgres:5432/rifa

API_DEV_TOKEN=change-me-long-random-api-token

# Optional public/admin URLs. If empty, web containers proxy /api internally to the API service.
VITE_API_BASE_URL=
VITE_PUBLIC_WEB_URL=
VITE_DEFAULT_RAFFLE_SLUG=

EMAIL_FROM=
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=

TELEGRAM_BOT_TOKEN=
TELEGRAM_SELLER_CHAT_ID=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=60
