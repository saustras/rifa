{
  "name": "db",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/db/src",
  "tags": ["scope:db"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/db/tsconfig.lib.json" },
      "outputs": ["{workspaceRoot}/dist/packages/db"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": { "command": "tsc -p packages/db/tsconfig.lib.json --noEmit" }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": { "command": "eslint packages/db/src --ext .ts" }
    }
  }
}
