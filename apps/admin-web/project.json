{
  "name": "admin-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/admin-web/src",
  "tags": ["type:web-app", "scope:admin-web"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite build --config apps/admin-web/vite.config.ts"
      },
      "outputs": ["{workspaceRoot}/dist/apps/admin-web"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vite --config apps/admin-web/vite.config.ts --host 0.0.0.0"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p apps/admin-web/tsconfig.app.json --noEmit"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --max-old-space-size=4096 ./node_modules/eslint/bin/eslint.js apps/admin-web/src --ext .ts,.tsx"
      }
    }
  }
}
